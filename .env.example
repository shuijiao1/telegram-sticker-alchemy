# Create a bot with @BotFather and paste the token here.
BOT_TOKEN=123456:REPLACE_ME

# Whitelist mode is enabled by default. Fill your Telegram numeric user id.
# You can get it from @userinfobot or @RawDataBot.
OWNER_ID=123456789

# Optional: allow multiple users, comma-separated. If set, this is used together with OWNER_ID.
# ALLOWED_USER_IDS=123456789,987654321

# Default: false. Keep false unless you intentionally want anyone to use the bot.
PUBLIC_ACCESS=false

TMP_DIR=/tmp/sticker-alchemy
